      <!-- ENTRY 3 -->
      <article class="entry" id="e3">
        <div class="entry-header">
          <span class="entry-num">03.</span>
          <span class="entry-title">Project Title Three</span>
          <span class="entry-type sound">sound</span>
          <span class="entry-type video">video</span>
        </div>
        <div class="entry-meta-row">
          <span>[year]</span>
          <span>20′ 00″</span>
          <span>site-specific</span>
        </div>
        <p class="entry-desc">
          A work existing across sound and image simultaneously —
          both present, neither explaining the other.
        </p>

        <div class="video-wrapper">
          <div class="video-placeholder">
            <span class="blink">▶</span>
            <span>replace with embed url</span>
          </div>
        </div>

        <div class="player" id="player-3">
          <button class="play-btn" onclick="togglePlay('player-3','audio-3')">play</button>
          <div class="player-inner">
            <div class="progress-track" onclick="seek(event,'audio-3','fill-3')">
              <div class="progress-fill" id="fill-3"></div>
            </div>
            <div class="player-meta">
              <span id="time-3">0:00</span>
              <span>soundscape_03.mp3</span>
              <span id="dur-3">--:--</span>
            </div>
          </div>
        </div>
        <audio id="audio-3" src="audio/project-three.mp3"
          ontimeupdate="updateProgress('audio-3','fill-3','time-3')"
          onloadedmetadata="setDuration('audio-3','dur-3')"
          onended="resetPlayer('player-3','fill-3','time-3')"></audio>

        <div class="tags">
          <span class="tag">refraction</span>
          <span class="tag">overlap</span>
          <span class="tag">site-specific</span>
        </div>
      </article>

    </div>
  </div>

  <footer>
    <span>redestorting a common spectacle — [your name]</span>
    <span>made with html. no cookies. no tracking.</span>
    <span><a href="mailto:your@email.com">your@email.com</a></span>
  </footer>

</div>

<script>
  // BOOT
  const lines = [
    {id:'b0',delay:80},{id:'b1',delay:350},{id:'b2',delay:620},
    {id:'b3',delay:850},{id:'b4',delay:1050},{id:'b5',delay:1300},
    {id:'b6',delay:1500},{id:'b7',delay:1800}
  ];
  lines.forEach(({id,delay}) => {
    setTimeout(() => { const el = document.getElementById(id); if(el) el.style.opacity='1'; }, delay);
  });

  function dismissBoot() {
    const boot = document.getElementById('boot');
    const main = document.getElementById('main-content');
    boot.style.transition = 'opacity 0.35s';
    boot.style.opacity = '0';
    setTimeout(() => { boot.style.display='none'; main.style.display='block'; }, 350);
  }

  setTimeout(() => {
    document.addEventListener('keydown', dismissBoot, {once:true});
    document.addEventListener('click', dismissBoot, {once:true});
  }, 2000);
  setTimeout(dismissBoot, 5500);

  // COUNTER
  document.getElementById('counter').textContent =
    String(4271 + Math.floor(Math.random()*99)).padStart(6,'0');

  // AUDIO
  function togglePlay(pid, aid) {
    const audio = document.getElementById(aid);
    const btn = document.querySelector(`#${pid} .play-btn`);
    document.querySelectorAll('audio').forEach(a => {
      if (a.id !== aid && !a.paused) {
        a.pause();
        const b = document.querySelector(`#${a.id.replace('audio','player')} .play-btn`);
        if (b) b.textContent = 'play';
      }
    });
    if (audio.paused) { audio.play(); btn.textContent = 'stop'; }
    else              { audio.pause(); btn.textContent = 'play'; }
  }

  function updateProgress(aid, fid, tid) {
    const a = document.getElementById(aid);
    const f = document.getElementById(fid);
    const t = document.getElementById(tid);
    if (a.duration) f.style.width = (a.currentTime / a.duration * 100) + '%';
    const m = Math.floor(a.currentTime/60);
    const s = String(Math.floor(a.currentTime%60)).padStart(2,'0');
    t.textContent = `${m}:${s}`;
  }

  function setDuration(aid, did) {
    const a = document.getElementById(aid);
    const d = document.getElementById(did);
    const m = Math.floor(a.duration/60);
    const s = String(Math.floor(a.duration%60)).padStart(2,'0');
    d.textContent = `${m}:${s}`;
  }

  function seek(e, aid, fid) {
    const a = document.getElementById(aid);
    const r = e.currentTarget.getBoundingClientRect();
    a.currentTime = ((e.clientX - r.left) / r.width) * a.duration;
  }

  function resetPlayer(pid, fid, tid) {
    const b = document.querySelector(`#${pid} .play-btn`);
    if (b) b.textContent = 'play';
    document.getElementById(fid).style.width = '0%';
    document.getElementById(tid).textContent = '0:00';
  }
</script>

</body>
