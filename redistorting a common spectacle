  <div class="line" id="b7">press any key to continue <span class="cursor"></span></div>
</div>

<!-- MAIN -->
<div id="main-content">

  <div class="marquee-band">
    <span class="marquee-inner">
      &nbsp;&nbsp;&nbsp;&nbsp;* redestorting a common spectacle *&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
      sound / moving image&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
      * new work online *&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
      this site is best experienced with your ears open&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
      * redestorting a common spectacle *&nbsp;&nbsp;&nbsp;&nbsp;
    </span>
  </div>

  <header>
    <div class="site-title">REDESTORTING A COMMON SPECTACLE</div>
    <div class="site-subtitle">— sound &amp; moving image</div>
    <div class="header-meta">last updated: [date] &nbsp;|&nbsp; <a href="mailto:your@email.com">contact</a></div>
  </header>

  <nav>
    <a href="#" class="active">all works</a>
    <a href="#">sound</a>
    <a href="#">video</a>
    <a href="#">about</a>
    <a href="#">links</a>
  </nav>

  <div class="layout">

    <aside class="sidebar-left">
      <h3>index</h3>
      <ul>
        <li><a href="#e1">Project One</a></li>
        <li><a href="#e2">Project Two</a></li>
        <li><a href="#e3">Project Three</a></li>
      </ul>

      <h3>about</h3>
      <p>
