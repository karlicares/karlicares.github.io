<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>redestorting a common spectacle</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #e8e4dc;
      color: #111;
      font-family: "Courier New", Courier, monospace;
      font-size: 13px;
      line-height: 1.6;
      cursor: crosshair;
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.025) 2px,
        rgba(0,0,0,0.025) 4px
      );
      pointer-events: none;
      z-index: 9999;
    }

    a { color: #0000cc; }
    a:visited { color: #551a8b; }
    a:hover { color: #cc0000; background: #ffff00; }

    /* BOOT */
    #boot {
      position: fixed;
      inset: 0;
      background: #000;
      color: #33ff33;
      font-family: "Courier New", monospace;
      font-size: 13px;
      padding: 2rem;
      z-index: 10000;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    #boot .line { opacity: 0; white-space: pre; }

    .cursor {
      display: inline-block;
      width: 8px; height: 14px;
      background: #33ff33;
      animation: blink 0.8s step-end infinite;
      vertical-align: middle;
    }

    @keyframes blink { 50% { opacity: 0; } }

    #main-content { display: none; }

    /* MARQUEE */
    .marquee-band {
      background: #000;
      color: #ffff00;
      font-size: 11px;
      padding: 3px 0;
      overflow: hidden;
      white-space: nowrap;
    }
    .marquee-inner {
      display: inline-block;
      animation: marquee 32s linear infinite;
    }
    @keyframes marquee {
      from { transform: translateX(100vw); }
      to   { transform: translateX(-100%); }
    }

    /* HEADER */
    header {
      border-bottom: 2px solid #000;
      padding: 10px 16px 8px;
      background: #fff;
      display: flex;
      align-items: baseline;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .site-title {
      font-size: 14px;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .site-subtitle {
      font-size: 12px;
      font-style: italic;
      font-weight: normal;
      color: #444;
    }

    .header-meta {
      font-size: 11px;
      color: #666;
      margin-left: auto;
    }

    /* NAV */
    nav {
      background: #000;
      padding: 4px 16px;
      display: flex;
      gap: 0;
      flex-wrap: wrap;
    }

    nav a {
      color: #fff;
      text-decoration: none;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 3px 12px;
      border-right: 1px solid #333;
    }

    nav a:hover { background: #ffff00; color: #000; }
    nav a.active { background: #cc0000; color: #fff; }

    /* LAYOUT */
    .layout { display: flex; align-items: flex-start; }

    /* SIDEBAR */
    .sidebar-left {
      width: 175px;
      flex-shrink: 0;
      border-right: 1px solid #000;
      min-height: calc(100vh - 80px);
      padding: 12px 10px;
      background: #f0ece3;
      font-size: 11px;
    }

    .sidebar-left h3 {
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      border-bottom: 1px solid #000;
      padding-bottom: 3px;
      margin-bottom: 7px;
      margin-top: 16px;
    }

    .sidebar-left h3:first-child { margin-top: 0; }

    .sidebar-left ul { list-style: none; display: flex; flex-direction: column; gap: 2px; }
    .sidebar-left li::before { content: "> "; color: #cc0000; }
    .sidebar-left p { color: #555; line-height: 1.7; font-style: italic; }

    .counter {
      margin-top: 18px;
      background: #000;
      color: #33ff33;
      text-align: center;
      padding: 5px 8px;
      font-size: 13px;
      letter-spacing: 0.3em;
      border: 1px solid #333;
    }

    .counter-label {
      font-size: 9px;
      color: #888;
      text-align: center;
      margin-top: 2px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    /* FEED */
    .feed { flex: 1; }

    .entry {
      border-bottom: 1px dashed #aaa;
      padding: 16px 20px;
    }

    .entry:nth-child(even) { background: #f3f0e8; }

    .entry-header {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 5px;
      flex-wrap: wrap;
    }

    .entry-num { font-size: 10px; color: #aaa; min-width: 22px; }

    .entry-title {
      font-size: 14px;
      font-weight: bold;
      text-decoration: underline;
      cursor: crosshair;
    }

    .entry-title:hover { color: #cc0000; background: #ffff00; }

    .entry-type {
      font-size: 9px;
      text-transform: uppercase;
      border: 1px solid #000;
      padding: 1px 5px;
      letter-spacing: 0.1em;
      background: #fff;
    }

    .entry-type.video { background: #000; color: #fff; }

    .entry-meta-row {
      font-size: 10px;
      color: #777;
      margin-bottom: 8px;
      display: flex;
      gap: 14px;
    }

    .entry-desc {
      font-size: 12px;
      color: #333;
      max-width: 540px;
      margin-bottom: 12px;
      line-height: 1.9;
    }

    /* PLAYER */
    .player {
      border: 1px solid #000;
      background: #fff;
      display: inline-flex;
      align-items: stretch;
      max-width: 460px;
      width: 100%;
      margin-bottom: 10px;
    }

    .play-btn {
      background: #000;
      color: #fff;
      border: none;
      border-right: 1px solid #000;
      padding: 0 12px;
      font-family: "Courier New", monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      cursor: crosshair;
      flex-shrink: 0;
    }

    .play-btn:hover { background: #cc0000; }

    .player-inner {
      padding: 6px 10px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .progress-track {
      width: 100%;
      height: 7px;
      background: #ddd;
      border: 1px solid #bbb;
      cursor: crosshair;
      position: relative;
    }

    .progress-fill {
      height: 100%;
      background: #000;
      width: 0%;
      pointer-events: none;
    }

    .player-meta {
      display: flex;
      justify-content: space-between;
      font-size: 9px;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* VIDEO */
    .video-wrapper {
      border: 2px solid #000;
      position: relative;
      padding-bottom: 56.25%;
      height: 0;
      overflow: hidden;
      max-width: 560px;
      margin-bottom: 10px;
    }

    .video-wrapper iframe {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
      border: none;
    }

    .video-placeholder {
      position: absolute;
      inset: 0;
      background: #000;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 10px;
      color: #33ff33;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .video-placeholder .blink { animation: blink 1s step-end infinite; font-size: 22px; }

    /* TAGS */
    .tags { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 8px; }

    .tag {
      font-size: 10px;
      border: 1px solid #aaa;
      padding: 1px 6px;
      color: #666;
      background: #fff;
    }

    .tag:hover { background: #ffff00; cursor: crosshair; }

    /* FOOTER */
    footer {
      border-top: 2px solid #000;
      background: #fff;
      padding: 9px 16px;
      font-size: 10px;
      color: #666;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 4px;
    }

    @media(max-width: 600px) {
      .sidebar-left { display: none; }
    }
  </style>
</head>
<body>

<!-- BOOT -->
<div id="boot">
