      </ul>

      <div class="counter" id="counter">000000</div>
      <div class="counter-label">visitors since [year]</div>
    </aside>

    <div class="feed">

      <!-- ENTRY 1 -->
      <article class="entry" id="e1">
        <div class="entry-header">
          <span class="entry-num">01.</span>
          <span class="entry-title">Project Title One</span>
          <span class="entry-type sound">sound</span>
        </div>
        <div class="entry-meta-row">
          <span>[year]</span>
          <span>12′ 40″</span>
